# Credentials — never commit
.credentials.json
settings.json
settings.local.json

# Conversation & session state
history.jsonl
mcp-needs-auth-cache.json
paste-cache/
session-env/
shell-snapshots/
backups/

# Runtime & cache
cache/
plugins/
projects/
file-history/
downloads/

# Research workspace — user-created projects (runtime, not config)
research/projects/

# Community skills installed via git clone (runtime, installed by setup-research.sh)
research/.claude/skills/*/
# Custom dotclaude skills (tracked in repo)
!research/.claude/skills/seminar-prep/

# npx skills lock file (runtime artifact)
skills-lock.json

# Community skills symlinked into ~/.claude/skills/ by npx skills --global
# gemini-web-fetch is the only custom skill tracked here; others are community-installed
skills/brainstorming
skills/prd-development
skills/writing-plans
skills/verification-before-completion

# OS
.DS_Store
